<!doctype html>
<html lang="en">
  <head>
    <script type="module">import { injectIntoGlobalHook } from "/@react-refresh";
injectIntoGlobalHook(window);
window.$RefreshReg$ = () => {};
window.$RefreshSig$ = () => (type) => type;</script>

    <script type="module" src="/@vite/client"></script>

    <meta charset="UTF-8" />

    <!-- تغيير أيقونة التبويب (Favicon) لتصبح صورتك الشخصية مباشرة -->
    <link rel="icon" type="image/jpeg" href="/src/assets/Alisayed1.jpg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- عنوان الموقع الرئيسي على المتصفح -->
    <title>Ali Sayed | Front-End Developer Portfolio</title>

    <!-- وسوم الـ SEO الأساسية لمحركات البحث -->
    <meta
      name="description"
      content="Professional Front-End Developer portfolio of Ali Sayed. Specializing in building interactive, high-performance, and fully responsive web applications using React.js and modern tech stacks."
    />
    <meta
      name="keywords"
      content="Ali Sayed, Ali Sayed Ali, Front-End Developer, React Developer, UI/UX, Web Developer Cairo, Portfolio, Tailwind CSS, Framer Motion"
    />
    <meta name="author" content="Ali Sayed" />

    <!-- وسوم الـ Open Graph (لإظهار كارت معاينة فخم وصورة عند مشاركة رابط موقعك على LinkedIn أو WhatsApp) -->
    <meta property="og:type" content="website" />
    <meta
      property="og:title"
      content="Ali Sayed | Front-End Developer Portfolio"
    />
    <meta
      property="og:description"
      content="I transform creative ideas and designs into interactive, fast, and fully responsive user interfaces."
    />
    <meta property="og:image" content="/src/assets/Alisayed1.jpg" />
    <meta property="og:url" content="https://your-portfolio-domain.com" />

    <!-- استدعاء الخطوط الرسمية من Google Fonts ليتطابق مع ثيم الـ CSS الخاص بك -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <!-- الحاوية الرئيسية لتطبيق الـ React -->
    <div id="root"></div>

    <!-- ملف التشغيل الرئيسي للتطبيق -->
    <script type="module" src="/src/main.jsx?t=1780749367597"></script>
  </body>
</html>
